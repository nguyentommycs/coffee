DATABASE_URL=postgresql://user:password@localhost:5432/coffee_agent

# Brave Search API — free tier: 2000 queries/month
# Sign up at https://api.search.brave.com/
BRAVE_API_KEY=your_brave_api_key_here

# Google AI Studio (Gemini) — free tier available
# Get a key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Optional: override the default model (gemini-1.5-flash is the free tier)
# GEMINI_MODEL=gemini-3.1-flash-lite-preview
